{
  "name": "@document-designer/package",
  "version": "0.1.0",
  "description": "Core reusable del document designer con utilidades headless y contratos de tour.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./tour": {
      "types": "./dist/tour/index.d.ts",
      "default": "./dist/tour/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "document-designer",
    "report-designer",
    "headless",
    "typescript",
    "react",
    "vue",
    "angular"
  ],
  "repository": {
    "type": "git",
    "url": "."
  },
  "license": "MIT",
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core/index.d.ts"
      ],
      "tour": [
        "./dist/tour/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
